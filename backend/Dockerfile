# Используем стабильную версию Node.js
FROM node:18-alpine

# Устанавливаем рабочую директорию
WORKDIR /app

# Копируем файлы зависимостей
COPY package*.json ./

# Устанавливаем только необходимые для продакшена пакеты
RUN npm install --production

# Копируем исходный код
COPY . .

# Открываем порт, который прописан в твоем Express (по умолчанию 5000)
EXPOSE 5000

# Запускаем сервер
CMD ["node", "server.js"]